# Base URL for google-sso-user-service (via API gateway or direct)
NEXT_PUBLIC_SSO_API_BASE_URL=http://localhost:8080/api/v1

# URL this app is hosted at — used for Google OAuth redirect
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Keycloak local realm/client for suite-wide SSO
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8081
NEXT_PUBLIC_KEYCLOAK_REALM=seowallet
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=seowallet-web
